# Route /c/<slug> to the generic class registration page (reads the slug from the path)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Short share links. 302 on purpose: repoint to a future cycle's classes
  # without browsers caching the redirect forever. Query strings (?ref=...)
  # carry through automatically.
  RewriteRule ^legal-update/?$ /c/legal-update-i [R=302,L,NE]
  RewriteRule ^legal-updates/?$ /c/legal-update-i [R=302,L,NE]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^c/[^/]+/?$ /c/index.html [L]
</IfModule>

# HTML must always revalidate: class prices, dates, and registration options
# change and a stale cached page can send someone to the wrong checkout.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
