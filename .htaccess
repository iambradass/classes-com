# Route /c/<slug> to the generic class registration page (reads the slug from the path)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^c/[^/]+/?$ /c/index.html [L]
</IfModule>

# HTML must always revalidate: class prices, dates, and registration options
# change and a stale cached page can send someone to the wrong checkout.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
